<?xml version="1.0" encoding="UTF-8"?>
<project name="examples.python" default="maven" basedir=".">
	<!-- import of the global SSE Jenkins properties -->
	<property file="${user.home}/global-build.properties"/>
	<property file="${user.home}/qualimaster-build.properties"/>
	<include file="${user.home}/macros.xml"/>
	
    <!-- intentionally no deployment here -->
	<target name="maven"> 
        <maven pomFile="pom.xml" goal="install">
            <arg value="-Dunpack.force=true"/>
            <arg value="-Diip.ciBuildId=${build_num}"/> <!-- must be set in jenkins ANT build step -->
            <arg value="-Dokto.mvn.home=${maven.bin.dir}/bin"/>
        </maven>
		<!-- convenience: pack sources and deploy to projects -->
        <delete file="target/examples.python-src.zip" failonerror="false"/> 
        <zip destFile="target/examples.python-src.zip" basedir=".">
        	<exclude name="target/**"/>
        </zip>
        <oscp todir="jenkins@projects.sse.uni-hildesheim.de:/var/www/oktoflow" trust="true" keyfile="${user.home}/.ssh/id_rsa">
            <fileset dir=".">
                <include name="target/examples.python-src.zip"/>
            </fileset>
        </oscp> 
	</target>
</project>
